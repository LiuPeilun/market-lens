# Runtime
MARKET_LENS_ENV=development
MARKET_LENS_HOST=127.0.0.1
MARKET_LENS_PORT=8000

# HTTP data source settings
MARKET_LENS_HTTP_TIMEOUT=15
MARKET_LENS_HTTP_RETRIES=2

# SQLite cache path
MARKET_LENS_DB_PATH=.data/market_lens.sqlite3

# LLM answer generation. The agent still uses deterministic tools for data retrieval.
MARKET_LENS_LLM_ENABLED=true
MARKET_LENS_LLM_BASE_URL=http://218.106.157.54:13006/v1
MARKET_LENS_LLM_MODEL=qwen3.5-27b
MARKET_LENS_LLM_API_KEY=
MARKET_LENS_LLM_TIMEOUT=60

# Optional future integrations
OPENAI_API_KEY=
DAYTONA_API_KEY=

# Supabase public application connection. Never put service-role keys in this file.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Isolated execution. Keep disabled until the selected backend is configured.
MARKET_LENS_SANDBOX_BACKEND=disabled
MARKET_LENS_DOCKER_SANDBOX_IMAGE=python:3.11-slim
MARKET_LENS_DOCKER_SANDBOX_TEMP_ROOT=.tmp/sandboxes
